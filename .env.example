# Copy this file to .env and fill real values. NEVER commit .env.
# .env is gitignored.

# Database (matches docker-compose.yml)
DB_URL=jdbc:postgresql://localhost:5432/life_organizer
DB_USERNAME=life_organizer
DB_PASSWORD=life_organizer

# JWT signing secret - MUST be at least 32 characters of high-entropy random data.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=replace-with-32-or-more-random-characters-from-openssl

# Spring profile to activate (use "local" for development)
SPRING_PROFILES_ACTIVE=local
