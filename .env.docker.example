# Copy this file to .env (which is gitignored) before running
#   docker compose -f docker-compose.full.yml up --build
#
# The .env file is automatically picked up by docker compose.

# JWT signing secret. MUST be at least 32 characters of random data.
# Generate one with:  openssl rand -base64 48
JWT_SECRET=replace-this-with-at-least-32-characters-of-random-data-please
