# ---------------------------------------------------------------------------
# Life Organizer - production environment template (Slice 11).
# Copy to .env (gitignored) and fill in real values before deploying.
# Every variable below is referenced by application.yml or application-prod.yml.
# ---------------------------------------------------------------------------

# Spring profile: keep "prod" for real deployments.
SPRING_PROFILES_ACTIVE=prod

# Database (managed by your host or by docker-compose).
DB_URL=jdbc:postgresql://postgres:5432/life_organizer
DB_USERNAME=life_organizer
DB_PASSWORD=replace-me-with-a-strong-password

# JWT signing secret. Must be at least 32 high-entropy characters.
# Generate with:  openssl rand -base64 48
JWT_SECRET=replace-with-32-or-more-random-characters-from-openssl

# Public origin of the SPA. Used in mail links + CORS.
# Example for Fly.io: https://lifeorg.fly.dev
APP_MAIL_BASE_URL=https://your-app-domain.example
APP_CORS_ALLOWED_ORIGINS=https://your-app-domain.example

# ---------------------------------------------------------------------------
# Mail delivery (Slice 11). With provider=smtp the app sends real emails for
# verify, reset, change-email, and restore links. Leave provider=file (the
# default) only if you are a single-user self-host happy to read the
# .tmp/auth-dev-links.txt file.
# ---------------------------------------------------------------------------
APP_MAIL_PROVIDER=smtp
APP_MAIL_FROM_ADDRESS=no-reply@your-app-domain.example
APP_MAIL_FROM_NAME=Life Organizer

# Pick one of the example providers below. All use the same Spring Mail
# settings - just swap the host / port / credentials.

# Gmail SMTP (use a Google "App password", not your account password):
#   SPRING_MAIL_HOST=smtp.gmail.com
#   SPRING_MAIL_PORT=587
#   SPRING_MAIL_USERNAME=you@gmail.com
#   SPRING_MAIL_PASSWORD=your-16-char-app-password

# SendGrid:
#   SPRING_MAIL_HOST=smtp.sendgrid.net
#   SPRING_MAIL_PORT=587
#   SPRING_MAIL_USERNAME=apikey
#   SPRING_MAIL_PASSWORD=SG.xxxxxxxxxxxxxxxx

# Mailgun:
#   SPRING_MAIL_HOST=smtp.mailgun.org
#   SPRING_MAIL_PORT=587
#   SPRING_MAIL_USERNAME=postmaster@your-domain.example
#   SPRING_MAIL_PASSWORD=mailgun-smtp-password

# Mailtrap (development sandbox - safe to use while testing):
#   SPRING_MAIL_HOST=sandbox.smtp.mailtrap.io
#   SPRING_MAIL_PORT=2525
#   SPRING_MAIL_USERNAME=your-mailtrap-username
#   SPRING_MAIL_PASSWORD=your-mailtrap-password

SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_STARTTLS=true
SPRING_MAIL_AUTH=true

# Explicitly disable the dev-delivery file in production (defense in depth -
# the prod profile already disables it).
APP_AUTH_DEV_DELIVERY_ENABLED=false
